<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════
         NAN'S HOI4 TOOL  ·  GLOBAL STYLES  ·  v2
    ═══════════════════════════════════════════════════════════════════ -->

    <!-- ── Scrollbars ──────────────────────────────────────────────────── -->
    <Style x:Key="ThinScrollThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="B" Background="#36FFFFFF" CornerRadius="3" Margin="2,0"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="B" Property="Background" Value="#66FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="B" Property="Background" Value="#99FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ThinScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="7"/>
        <Setter Property="MinWidth" Value="7"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent" Width="7">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton><RepeatButton Opacity="0" IsHitTestVisible="False"/></Track.DecreaseRepeatButton>
                            <Track.Thumb><Thumb Style="{StaticResource ThinScrollThumb}"/></Track.Thumb>
                            <Track.IncreaseRepeatButton><RepeatButton Opacity="0" IsHitTestVisible="False"/></Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="1"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ThinHScrollBarStyle" TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}">
        <Setter Property="Height" Value="7"/>
        <Setter Property="Width"  Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent" Height="7">
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton><RepeatButton Opacity="0" IsHitTestVisible="False"/></Track.DecreaseRepeatButton>
                            <Track.Thumb><Thumb Style="{StaticResource ThinScrollThumb}"/></Track.Thumb>
                            <Track.IncreaseRepeatButton><RepeatButton Opacity="0" IsHitTestVisible="False"/></Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility"   Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <!-- ── AppCard ── surfaced card with border and subtle shadow ─────────── -->
    <Style x:Key="AppCard" TargetType="Border">
        <Setter Property="Background"       Value="#1A1C27"/>
        <Setter Property="BorderBrush"      Value="#2C2F43"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="10"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.35" Color="#000000" Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── GlassCard ── frosted glass card ──────────────────────────────── -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background"      Value="#14FFFFFF"/>
        <Setter Property="BorderBrush"     Value="#20FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="10"/>
    </Style>

    <!-- ── Section label ──────────────────────────────────────────────── -->
    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Opacity"    Value="0.4"/>
        <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
        <Setter Property="Margin"     Value="0,0,0,6"/>
    </Style>

    <!-- ── Heading ────────────────────────────────────────────────────── -->
    <Style x:Key="HeadingLg" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="26"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
        <Setter Property="Margin"     Value="0,0,0,6"/>
    </Style>
    <Style x:Key="HeadingMd" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
    </Style>
    <Style x:Key="HeadingSm" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
        <Setter Property="Margin"     Value="0,0,0,12"/>
    </Style>

    <!-- ── Body / caption text ────────────────────────────────────────── -->
    <Style x:Key="BodyMd" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Opacity"    Value="0.55"/>
        <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ── Separator ─────────────────────────────────────────────────── -->
    <Style x:Key="AppSeparator" TargetType="Border">
        <Setter Property="Height"     Value="1"/>
        <Setter Property="Background" Value="#1EFFFFFF"/>
        <Setter Property="Margin"     Value="0,8"/>
    </Style>

    <!-- ── Pill / badge ──────────────────────────────────────────────── -->
    <Style x:Key="PillAccent" TargetType="Border">
        <Setter Property="Background"    Value="#226366F1"/>
        <Setter Property="BorderBrush"   Value="#446366F1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"  Value="999"/>
        <Setter Property="Padding"       Value="8,3"/>
    </Style>
    <Style x:Key="PillSuccess" TargetType="Border">
        <Setter Property="Background"    Value="#2022C55E"/>
        <Setter Property="BorderBrush"   Value="#4422C55E"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"  Value="999"/>
        <Setter Property="Padding"       Value="8,3"/>
    </Style>
    <Style x:Key="PillWarning" TargetType="Border">
        <Setter Property="Background"    Value="#20F59E0B"/>
        <Setter Property="BorderBrush"   Value="#44F59E0B"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"  Value="999"/>
        <Setter Property="Padding"       Value="8,3"/>
    </Style>
    <Style x:Key="PillError" TargetType="Border">
        <Setter Property="Background"    Value="#20EF4444"/>
        <Setter Property="BorderBrush"   Value="#44EF4444"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"  Value="999"/>
        <Setter Property="Padding"       Value="8,3"/>
    </Style>

    <!-- ── Accent glow button ────────────────────────────────────────── -->
    <Style x:Key="GlowButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"
                xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.6" Color="#6366F1"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Ghost icon button ─────────────────────────────────────────── -->
    <Style x:Key="GhostIconBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}"
           xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
        <Setter Property="Opacity" Value="0.5"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="1"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Chat bubble styles ────────────────────────────────────────── -->
    <Style x:Key="ChatBubbleOwn" TargetType="Border">
        <Setter Property="Background"    Value="#6366F1"/>
        <Setter Property="CornerRadius"  Value="12,12,2,12"/>
        <Setter Property="Padding"       Value="10,6"/>
        <Setter Property="MaxWidth"      Value="280"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>
    <Style x:Key="ChatBubbleOther" TargetType="Border">
        <Setter Property="Background"    Value="#21233A"/>
        <Setter Property="BorderBrush"   Value="#2C2F43"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"  Value="12,12,12,2"/>
        <Setter Property="Padding"       Value="10,6"/>
        <Setter Property="MaxWidth"      Value="280"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- ── Online presence dot ───────────────────────────────────────── -->
    <Style x:Key="PresenceDot" TargetType="Ellipse">
        <Setter Property="Width"  Value="8"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Fill"   Value="#22C55E"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.8" Color="#22C55E"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Sidebar nav button ─────────────────────────────────────────── -->
    <Style x:Key="NavBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}"
           xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Height"  Value="40"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6"/>
        <Setter Property="Margin"  Value="6,1"/>
    </Style>

    <!-- ── Input hint label ──────────────────────────────────────────── -->
    <Style x:Key="InputLabel" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="10"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Opacity"    Value="0.6"/>
        <Setter Property="Margin"     Value="2,0,0,4"/>
        <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
    </Style>

    <!-- ── Version badge ─────────────────────────────────────────────── -->
    <Style x:Key="VersionBadge" TargetType="Border">
        <Setter Property="Background"    Value="#10FFFFFF"/>
        <Setter Property="BorderBrush"   Value="#14FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"  Value="6"/>
        <Setter Property="Padding"       Value="8,3"/>
    </Style>

    <!-- ── Page fade-in ──────────────────────────────────────────────── -->
    <Style x:Key="FadeContentControl" TargetType="ContentControl">
        <Setter Property="RenderTransform"><Setter.Value><TranslateTransform Y="0"/></Setter.Value></Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.22">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
