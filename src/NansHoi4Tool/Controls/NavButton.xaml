<UserControl x:Class="NansHoi4Tool.Controls.NavButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:NansHoi4Tool.Helpers">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:PageKeyToSelectedConverter x:Key="PageToSelected"/>
    </UserControl.Resources>

    <Button x:Name="Btn"
            Height="40"
            Command="{Binding NavCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            CommandParameter="{Binding PageKey, RelativeSource={RelativeSource AncestorType=UserControl}}"
            ToolTip="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
            HorizontalContentAlignment="Left"
            Padding="0"
            BorderThickness="0"
            Cursor="Hand">
        <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Margin" Value="4,1"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Style.Triggers>
                    <DataTrigger Value="True">
                        <DataTrigger.Binding>
                            <MultiBinding Converter="{StaticResource PageToSelected}">
                                <Binding Path="CurrentPage" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                <Binding Path="PageKey" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                            </MultiBinding>
                        </DataTrigger.Binding>
                        <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Accent4}"/>
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Button.Style>
        <Grid Height="40" Width="204">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Left accent bar for selected -->
            <Border Grid.Column="0" Grid.ColumnSpan="2" CornerRadius="6"
                    Background="{DynamicResource MahApps.Brushes.Accent4}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource PageToSelected}">
                                        <Binding Path="CurrentPage" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                        <Binding Path="PageKey" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <materialDesign:PackIcon Grid.Column="0"
                                     Kind="{Binding Icon, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     Width="20" Height="20"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       VerticalAlignment="Center"
                       FontSize="13"
                       Visibility="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=UserControl},
                                    Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Button>
</UserControl>
