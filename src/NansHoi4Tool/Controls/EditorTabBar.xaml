<UserControl x:Class="NansHoi4Tool.Controls.EditorTabBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             x:Name="Root"
             Height="38">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Scrollable tab list -->
        <ScrollViewer Grid.Column="0"
                      x:Name="TabScroll"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      PreviewMouseWheel="OnPreviewMouseWheel">
            <ItemsControl ItemsSource="{Binding ElementName=Root, Path=Tabs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Tab button with active indicator -->
                        <Border x:Name="TabBorder"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Background="Transparent"
                                MinWidth="90" Height="38"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding ElementName=Root, Path=SelectTabCommand}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#18FFFFFF"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                            <Setter Property="Background" Value="#12FFFFFF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="14,0,6,0">
                                <TextBlock Text="{Binding Label}"
                                           FontSize="12" FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Opacity" Value="0.6"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Close button -->
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Width="18" Height="18"
                                        Padding="0"
                                        Margin="6,0,0,0"
                                        Visibility="{Binding CanClose, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding ElementName=Root, Path=CloseTabCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Close">
                                    <materialDesign:PackIcon Kind="Close" Width="11" Height="11"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Add new tab button -->
        <Button Grid.Column="1"
                Style="{StaticResource MaterialDesignIconButton}"
                Width="38" Height="38"
                Command="{Binding ElementName=Root, Path=AddCommand}"
                ToolTip="Add new">
            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18"/>
        </Button>

        <!-- Bottom separator line -->
        <Border Grid.Column="0" Grid.ColumnSpan="2"
                Height="1" VerticalAlignment="Bottom"
                Background="{DynamicResource MahApps.Brushes.Separator}"/>
    </Grid>
</UserControl>
