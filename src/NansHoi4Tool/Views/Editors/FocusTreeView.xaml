<UserControl x:Class="NansHoi4Tool.Views.Editors.FocusTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:NansHoi4Tool.Helpers"
             xmlns:controls="clr-namespace:NansHoi4Tool.Controls"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1200"
             Background="{DynamicResource MahApps.Brushes.ThemeBackground}">

    <UserControl.Resources>
        <helpers:FocusGridConverter x:Key="GridConv"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- tree tab bar -->
            <RowDefinition Height="Auto"/>  <!-- toolbar -->
            <RowDefinition Height="*"/>     <!-- canvas + right panel -->
        </Grid.RowDefinitions>

        <!-- ══ Tree tab bar ══════════════════════════════════════════════ -->
        <controls:EditorTabBar Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                               Tabs="{Binding Trees}"
                               AddCommand="{Binding AddTreeCommand}"
                               SelectTabCommand="{Binding SelectTreeCommand}"
                               CloseTabCommand="{Binding RemoveTreeCommand}"/>

        <!-- ══ Toolbar ══════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#0F1018" BorderBrush="#14FFFFFF" BorderThickness="0,0,0,1" Padding="10,6">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource GlowButton}"
                            Command="{Binding AddFocusCommand}"
                            Padding="12,5" Margin="0,0,6,0" Height="30">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,5,0" Width="13" Height="13"/>
                            <TextBlock Text="Add Focus" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource GhostIconBtn}"
                            Command="{Binding DuplicateFocusCommand}"
                            CommandParameter="{Binding ActiveTree.SelectedNode}"
                            Padding="11,5" Margin="0,0,6,0" Height="30" FontSize="11">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentCopy" Width="13" Height="13"
                                                     VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Duplicate" VerticalAlignment="Center" FontSize="11" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource GhostIconBtn}"
                            Command="{Binding DeleteFocusCommand}"
                            CommandParameter="{Binding ActiveTree.SelectedNode}"
                            Padding="11,5" Margin="0,0,10,0" Height="30" Opacity="0.7">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DeleteOutline" Width="13" Height="13"
                                                     Foreground="#EF4444" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Delete" Foreground="#EF4444" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="#14FFFFFF" Margin="4,4,10,4"/>

                    <!-- Connect mode toggle -->
                    <ToggleButton x:Name="ConnectToggle"
                                  IsChecked="{Binding ConnectModeActive}"
                                  Style="{StaticResource MaterialDesignOutlinedButton}"
                                  materialDesign:ButtonAssist.CornerRadius="6"
                                  Padding="11,5" Margin="0,0,6,0" Height="30"
                                  Foreground="White" BorderBrush="#2C2F43"
                                  ToolTip="Click two nodes to connect them">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="VectorLine" VerticalAlignment="Center" Margin="0,0,5,0" Width="13" Height="13"/>
                            <TextBlock Text="Connect" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </ToggleButton>

                    <Border Visibility="{Binding ConnectModeActive, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Prerequisite"
                                         GroupName="ConnType"
                                         IsChecked="{Binding PendingConnectionType,
                                             Converter={x:Static helpers:EnumToBoolConverter.Instance},
                                             ConverterParameter=Prerequisite}"
                                         Style="{StaticResource MaterialDesignRadioButton}"
                                         Foreground="White" Margin="0,0,8,0" FontSize="11"/>
                            <RadioButton Content="Mutex"
                                         GroupName="ConnType"
                                         IsChecked="{Binding PendingConnectionType,
                                             Converter={x:Static helpers:EnumToBoolConverter.Instance},
                                             ConverterParameter=MutuallyExclusive}"
                                         Style="{StaticResource MaterialDesignRadioButton}"
                                         Foreground="White" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <Border Width="1" Background="#14FFFFFF" Margin="4,4,10,4"/>

                    <TextBlock Text="Tree ID" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="10"
                               Foreground="White" Opacity="0.4"/>
                    <TextBox materialDesign:HintAssist.Hint="tree_id"
                             materialDesign:HintAssist.IsFloating="False"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding TreeId, UpdateSourceTrigger=PropertyChanged}"
                             Width="130" Height="26" Margin="0,0,10,0"
                             VerticalContentAlignment="Center" FontSize="11"/>
                    <TextBlock Text="TAG" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="10"
                               Foreground="White" Opacity="0.4"/>
                    <TextBox materialDesign:HintAssist.Hint="TAG"
                             materialDesign:HintAssist.IsFloating="False"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding CountryTag, UpdateSourceTrigger=PropertyChanged}"
                             Width="64" Height="26" VerticalContentAlignment="Center" FontSize="11"
                             IsReadOnly="{Binding IsGeneric}"/>
                    <CheckBox Content="Generic" IsChecked="{Binding IsGeneric}"
                              Style="{StaticResource MaterialDesignCheckBox}"
                              Foreground="White" Margin="10,0,0,0" FontSize="11"/>
                </StackPanel>

                <Border DockPanel.Dock="Right" Background="#1A6366F1" CornerRadius="5"
                        Padding="10,4" Margin="0,0,6,0" VerticalAlignment="Center"
                        Visibility="{Binding ConnectModeActive, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="VectorLine" Width="13" Height="13"
                                                 Foreground="#818CF8" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Connect mode active" FontSize="10" Foreground="#818CF8" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- ══ Canvas ════════════════════════════════════════════════════ -->
        <ScrollViewer x:Name="FocusScrollViewer"
                      Grid.Row="2" Grid.Column="0"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#12131A">
            <Canvas x:Name="FocusCanvas"
                    Width="3000" Height="2000"
                    MouseMove="OnCanvasMouseMoveForCursor">

                <!-- Grid dots overlay -->
                <Canvas.Background>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,100,100" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing>
                                <GeometryDrawing.Geometry>
                                    <EllipseGeometry RadiusX="1.2" RadiusY="1.2" Center="50,50"/>
                                </GeometryDrawing.Geometry>
                                <GeometryDrawing.Brush>
                                    <SolidColorBrush Color="#28FFFFFF"/>
                                </GeometryDrawing.Brush>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Canvas.Background>

                <!-- Connection lines layer -->
                <ItemsControl ItemsSource="{Binding ActiveTree.Connections}"
                              Canvas.Top="0" Canvas.Left="0"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="3000" Height="2000"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                  X2="{Binding X2}" Y2="{Binding Y2}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                <Line.Style>
                                    <Style TargetType="Line">
                                        <Setter Property="Stroke" Value="#5599FF"/>
                                        <Setter Property="StrokeDashArray" Value=""/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="MutuallyExclusive">
                                                <Setter Property="Stroke" Value="#FF5555"/>
                                                <Setter Property="StrokeDashArray" Value="5 3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Line.Style>
                            </Line>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Live cursor preview line (connect mode) -->
                <Line x:Name="CursorLine"
                      Canvas.Top="0" Canvas.Left="0"
                      IsHitTestVisible="False"
                      Stroke="#FFCC44"
                      StrokeThickness="2"
                      StrokeDashArray="6 3"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Opacity="0.8"
                      Visibility="Collapsed"/>

                <!-- Focus nodes -->
                <ItemsControl ItemsSource="{Binding ActiveTree.FocusNodes}"
                              Canvas.Top="0" Canvas.Left="0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="3000" Height="2000"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X, Converter={StaticResource GridConv}}"/>
                            <Setter Property="Canvas.Top"  Value="{Binding Y, Converter={StaticResource GridConv}}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="96" Height="96"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Command="{Binding DataContext.SelectNodeCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Padding="4" ToolTip="{Binding Name}">
                                <Grid>
                                    <!-- Cost badge -->
                                    <Border Width="26" Height="16" CornerRadius="3"
                                            Background="#CC1A1A2E"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Canvas.ZIndex="10"
                                            Margin="0,-2,-2,0">
                                        <TextBlock Text="{Binding Cost}" FontSize="9"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="#FFCC44"/>
                                    </Border>
                                    <!-- Main node body -->
                                    <Border Width="80" Height="80" CornerRadius="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2A2D3E"/>
                                                <Setter Property="BorderThickness" Value="1.5"/>
                                                <Setter Property="BorderBrush" Value="#3A3D50"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                                        <Setter Property="Background" Value="#1E3A5A"/>
                                                        <Setter Property="BorderThickness" Value="2.5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsConnectSource}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#FFCC44"/>
                                                        <Setter Property="Background" Value="#2E2A1A"/>
                                                        <Setter Property="BorderThickness" Value="2.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <materialDesign:PackIcon Kind="StarCircle" Width="30" Height="30"
                                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                     HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" FontSize="9"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextAlignment="Center" MaxWidth="74"
                                                       Foreground="White" Margin="3,3,3,0" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Canvas>
        </ScrollViewer>

        <!-- ══ Right panel ═══════════════════════════════════════════════ -->
        <Border Grid.Row="2" Grid.Column="1"
                BorderBrush="#14FFFFFF" BorderThickness="1,0,0,0" Background="#0C0D12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12,14,12,14">

                    <!-- Section header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="TuneVariant" Width="15" Height="15"
                                                 Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="Focus Properties" Style="{StaticResource SectionLabel}"/>
                    </StackPanel>

                    <!-- Properties panel -->
                    <StackPanel DataContext="{Binding ActiveTree.SelectedNode}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="Focus ID" Style="{StaticResource InputLabel}"/>
                        <TextBox materialDesign:HintAssist.Hint="focus_id"
                                 materialDesign:HintAssist.IsFloating="False"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8" FontSize="11" Height="32" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Display Name" Style="{StaticResource InputLabel}"/>
                        <TextBox materialDesign:HintAssist.Hint="Focus Name"
                                 materialDesign:HintAssist.IsFloating="False"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8" FontSize="11" Height="32" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Icon (GFX key)" Style="{StaticResource InputLabel}"/>
                        <TextBox materialDesign:HintAssist.Hint="GFX_focus_icon"
                                 materialDesign:HintAssist.IsFloating="False"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Icon, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8" FontSize="11" Height="32" VerticalContentAlignment="Center"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Cost" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="70" materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Cost, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="11" Height="32" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="X" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="0" materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding X, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="11" Height="32" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Y" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="0" materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Y, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="11" Height="32" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Description key" Style="{StaticResource InputLabel}"/>
                        <TextBox materialDesign:HintAssist.Hint="focus_id_desc"
                                 materialDesign:HintAssist.IsFloating="False"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8" FontSize="11" Height="32" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Completion Reward" Style="{StaticResource InputLabel}"/>
                        <TextBox materialDesign:HintAssist.Hint="# HOI4 script effects..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding CompletionReward, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" Height="68" FontSize="11"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                                 Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <CheckBox Content="Cancel if invalid" IsChecked="{Binding CancelIfInvalid}"
                                      Style="{StaticResource MaterialDesignCheckBox}"
                                      Foreground="White" FontSize="11" Margin="0,0,12,0"/>
                            <CheckBox Content="Cap if capitulated" IsChecked="{Binding AvailableIfCapitulated}"
                                      Style="{StaticResource MaterialDesignCheckBox}"
                                      Foreground="White" FontSize="11"/>
                        </StackPanel>

                        <!-- Prerequisites -->
                        <Border Background="#0A6366F1" CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <materialDesign:PackIcon Kind="ArrowRight" Width="12" Height="12"
                                                             Foreground="#5599FF" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Prerequisites" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#5599FF"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding Prerequisites}" Margin="0,0,0,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding}" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="#5599FF"/>
                                                <Button Grid.Column="1" Style="{StaticResource GhostIconBtn}"
                                                        Width="18" Height="18" Padding="0" Opacity="0.5"
                                                        Command="{Binding DataContext.RemovePrerequisiteCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Close" Width="10" Height="10"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PrereqInput" Grid.Column="0"
                                             materialDesign:HintAssist.Hint="Add prerequisite ID"
                                             materialDesign:HintAssist.IsFloating="False"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Height="28" VerticalContentAlignment="Center" FontSize="10"/>
                                    <Button Grid.Column="1" Style="{StaticResource GhostIconBtn}"
                                            Width="28" Height="28" Margin="3,0,0,0"
                                            Command="{Binding DataContext.AddPrerequisiteCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Text, ElementName=PrereqInput}">
                                        <materialDesign:PackIcon Kind="Plus" Width="12" Height="12"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Mutually Exclusive -->
                        <Border Background="#0AEF4444" CornerRadius="6" Padding="10,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <materialDesign:PackIcon Kind="CloseCircleOutline" Width="12" Height="12"
                                                             Foreground="#FF5555" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Mutually Exclusive" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#FF5555"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding MutuallyExclusive}" Margin="0,0,0,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding}" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="#FF5555"/>
                                                <Button Grid.Column="1" Style="{StaticResource GhostIconBtn}"
                                                        Width="18" Height="18" Padding="0" Opacity="0.5"
                                                        Command="{Binding DataContext.RemoveMutexCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Close" Width="10" Height="10"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MutexInput" Grid.Column="0"
                                             materialDesign:HintAssist.Hint="Add mutex ID"
                                             materialDesign:HintAssist.IsFloating="False"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Height="28" VerticalContentAlignment="Center" FontSize="10"/>
                                    <Button Grid.Column="1" Style="{StaticResource GhostIconBtn}"
                                            Width="28" Height="28" Margin="3,0,0,0"
                                            Command="{Binding DataContext.AddMutexCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Text, ElementName=MutexInput}">
                                        <materialDesign:PackIcon Kind="Plus" Width="12" Height="12"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,48,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveTree.SelectedNode}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <materialDesign:PackIcon Kind="CursorPointer" Width="40" Height="40"
                                                 Opacity="0.12" HorizontalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="Select a focus to edit" Opacity="0.25"
                                   HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="12"
                                   Foreground="White"/>
                        <TextBlock Text="or use Connect mode to link nodes"
                                   Opacity="0.15" HorizontalAlignment="Center" Margin="0,4,0,0" FontSize="10"
                                   Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
