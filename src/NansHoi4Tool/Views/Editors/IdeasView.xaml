<UserControl x:Class="NansHoi4Tool.Views.Editors.IdeasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- List Panel -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource MahApps.Brushes.Separator}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="12">
                    <TextBlock Text="National Spirits" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" Margin="0,0,0,8"/>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding AddIdeaCommand}"
                            materialDesign:ButtonAssist.CornerRadius="6"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Add Idea" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Ideas}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="8,2" CornerRadius="7" Cursor="Hand" Padding="10,9">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.SelectedIdea.Id,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Value="{Binding Id}">
                                                    <Setter Property="Background" Value="#1A6366F1"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#0EFFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectIdeaCommand,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium"
                                                   Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Slot}" FontSize="10" Opacity="0.4"
                                                   Foreground="White" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Right: Idea editor -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24" DataContext="{Binding SelectedIdea}">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- Page header -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource HeadingLg}"/>
                    <TextBlock Text="{Binding Slot}" Style="{StaticResource Caption}"/>
                </StackPanel>

                <!-- Identity card -->
                <Border Style="{StaticResource AppCard}" Padding="18" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <materialDesign:PackIcon Kind="TagOutline" Width="15" Height="15"
                                                     Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="Identity" Style="{StaticResource HeadingSm}"/>
                        </StackPanel>

                        <TextBlock Text="Spirit ID" Style="{StaticResource InputLabel}"/>
                        <TextBox materialDesign:HintAssist.Hint="spirit_id" materialDesign:HintAssist.IsFloating="False"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10" Height="34" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Display Name" Style="{StaticResource InputLabel}"/>
                        <TextBox materialDesign:HintAssist.Hint="Spirit Name" materialDesign:HintAssist.IsFloating="False"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10" Height="34" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Description" Style="{StaticResource InputLabel}"/>
                        <TextBox materialDesign:HintAssist.Hint="Description text..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" Height="60" VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Slot" Style="{StaticResource InputLabel}"/>
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          SelectedItem="{Binding Slot}" Height="34">
                                    <ComboBoxItem Content="political_advisor"/>
                                    <ComboBoxItem Content="theorist"/>
                                    <ComboBoxItem Content="army_chief"/>
                                    <ComboBoxItem Content="navy_chief"/>
                                    <ComboBoxItem Content="air_chief"/>
                                    <ComboBoxItem Content="high_command"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Picture (GFX key)" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="GFX_spirit_icon"
                                         materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Picture, UpdateSourceTrigger=PropertyChanged}"
                                         Height="34" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <CheckBox Content="Allowed in Civil War" IsChecked="{Binding AllowedCivilWar}"
                                  Style="{StaticResource MaterialDesignCheckBox}" Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- Modifiers card -->
                <Border Style="{StaticResource AppCard}" Padding="18">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TuneVariant" Width="15" Height="15"
                                                         Foreground="#F59E0B" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Modifiers" Style="{StaticResource HeadingSm}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource GlowButton}"
                                    Command="{Binding DataContext.AddModifierCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Padding="12,5" Height="28">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Width="12" Height="12"
                                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Add" VerticalAlignment="Center" FontSize="11"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Modifiers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="34"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 materialDesign:HintAssist.Hint="modifier_key"
                                                 materialDesign:HintAssist.IsFloating="False"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="32" VerticalContentAlignment="Center" FontSize="11"/>
                                        <TextBox Grid.Column="2"
                                                 materialDesign:HintAssist.Hint="0.1"
                                                 materialDesign:HintAssist.IsFloating="False"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="32" VerticalContentAlignment="Center" FontSize="11"/>
                                        <Button Grid.Column="3" Style="{StaticResource GhostIconBtn}"
                                                Width="28" Height="28" Padding="0" Margin="4,0,0,0" Opacity="0.5"
                                                Command="{Binding DataContext.RemoveModifierCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Width="13" Height="13"
                                                                     Foreground="#EF4444"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
