<UserControl x:Class="NansHoi4Tool.Views.Editors.UnitsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left list -->
        <Border Grid.Column="0" Background="#0C0D12" BorderBrush="#14FFFFFF" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="14,14,14,10" BorderBrush="#0EFFFFFF" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="TankOutline" Width="16" Height="16"
                                                 Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Units &amp; Equipment" Style="{StaticResource HeadingMd}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Padding="10,10,10,6">
                    <Button Style="{StaticResource GlowButton}"
                            Command="{Binding AddUnitCommand}"
                            HorizontalAlignment="Stretch" Padding="0,7">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Plus" Width="13" Height="13"
                                                     VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Add Unit" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Units}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="8,2" CornerRadius="7" Cursor="Hand" Padding="10,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.SelectedUnit.Id,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Value="{Binding Id}">
                                                    <Setter Property="Background" Value="#1A6366F1"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#0EFFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectUnitCommand,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium"
                                                   Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Category}" FontSize="10" Opacity="0.4"
                                                   Foreground="White" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Right editor -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24" DataContext="{Binding SelectedUnit}">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- Page header -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource HeadingLg}"/>
                    <TextBlock Text="{Binding Category}" Style="{StaticResource Caption}"/>
                </StackPanel>

                <!-- Identity card -->
                <Border Style="{StaticResource AppCard}" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <materialDesign:PackIcon Kind="TagOutline" Width="15" Height="15"
                                                     Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="Identity" Style="{StaticResource HeadingSm}"/>
                        </StackPanel>
                        <TextBlock Text="Unit ID" Style="{StaticResource InputLabel}"/>
                        <TextBox materialDesign:HintAssist.Hint="unit_id" materialDesign:HintAssist.IsFloating="False"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10" Height="34" VerticalContentAlignment="Center"/>
                        <TextBlock Text="Display Name" Style="{StaticResource InputLabel}"/>
                        <TextBox materialDesign:HintAssist.Hint="Unit Name" materialDesign:HintAssist.IsFloating="False"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10" Height="34" VerticalContentAlignment="Center"/>
                        <TextBlock Text="Category" Style="{StaticResource InputLabel}"/>
                        <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  SelectedItem="{Binding Category}" Height="34">
                            <ComboBoxItem Content="land"/>
                            <ComboBoxItem Content="naval"/>
                            <ComboBoxItem Content="air"/>
                            <ComboBoxItem Content="support"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Stats card -->
                <Border Style="{StaticResource AppCard}" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <materialDesign:PackIcon Kind="ChartBar" Width="15" Height="15"
                                                     Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="Base Stats" Style="{StaticResource HeadingSm}"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="Max Strength" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="100" materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding MaxStrength}" Height="32" VerticalContentAlignment="Center" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                                <TextBlock Text="Max Organisation" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="60" materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding MaxOrganisation}" Height="32" VerticalContentAlignment="Center" FontSize="12"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="Default Morale" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="0.30" materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding DefaultMorale}" Height="32" VerticalContentAlignment="Center" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                                <TextBlock Text="Weight" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="0.1" materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Weight}" Height="32" VerticalContentAlignment="Center" FontSize="12"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="Supply Use" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="0.04" materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding SupplyUse}" Height="32" VerticalContentAlignment="Center" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="Manpower" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="1000" materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Manpower}" Height="32" VerticalContentAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>