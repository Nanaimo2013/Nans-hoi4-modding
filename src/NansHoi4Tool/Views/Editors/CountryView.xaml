<UserControl x:Class="NansHoi4Tool.Views.Editors.CountryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:NansHoi4Tool.Controls"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource MahApps.Brushes.ThemeBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- country tab bar -->
            <RowDefinition Height="*"/>     <!-- form content -->
        </Grid.RowDefinitions>

        <!-- ══ Country tab bar ══════════════════════════════════════════════ -->
        <controls:EditorTabBar Grid.Row="0"
                               Tabs="{Binding Countries}"
                               AddCommand="{Binding AddCountryCommand}"
                               SelectTabCommand="{Binding SelectCountryCommand}"
                               CloseTabCommand="{Binding RemoveCountryCommand}"/>

        <!-- ══ Form content ═════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,20,28,28" DataContext="{Binding ActiveCountry}" MaxWidth="820">

                <!-- Page header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                    <Border Width="38" Height="38" CornerRadius="9" Background="#1A1C27"
                            BorderBrush="#2C2F43" BorderThickness="1" Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="Flag" Width="18" Height="18"
                                                 Foreground="#6366F1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Country Editor" Style="{StaticResource HeadingLg}"/>
                        <TextBlock Text="{Binding Tag}" Style="{StaticResource Caption}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Identity card -->
                <Border Style="{StaticResource AppCard}" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <materialDesign:PackIcon Kind="BadgeAccountOutline" Width="15" Height="15"
                                                     Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="Identity" Style="{StaticResource HeadingSm}"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="TAG" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="ENG" materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Tag, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="3" Height="34" VerticalContentAlignment="Center" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Country Name" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="United Kingdom" materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Height="34" VerticalContentAlignment="Center" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Adjective" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="British" materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Adjective, UpdateSourceTrigger=PropertyChanged}"
                                         Height="34" VerticalContentAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ideology" Style="{StaticResource InputLabel}"/>
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding DataContext.AvailableIdeologies,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding Ideology}" Height="34" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Capital State ID" Style="{StaticResource InputLabel}"/>
                                <TextBox materialDesign:HintAssist.Hint="1" materialDesign:HintAssist.IsFloating="False"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding CapitalState, UpdateSourceTrigger=PropertyChanged}"
                                         Height="34" VerticalContentAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Graphics & Flag card -->
                <Border Style="{StaticResource AppCard}" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <materialDesign:PackIcon Kind="Image" Width="15" Height="15"
                                                     Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="Graphics &amp; Flag" Style="{StaticResource HeadingSm}"/>
                        </StackPanel>
                        <TextBlock Text="Graphical Culture" Style="{StaticResource InputLabel}"/>
                        <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  ItemsSource="{Binding DataContext.AvailableGraphicalCultures,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  SelectedItem="{Binding GraphicalCulture}"
                                  Margin="0,0,0,10" Height="34" FontSize="12"/>
                        <TextBlock Text="Flag File Path" Style="{StaticResource InputLabel}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     materialDesign:HintAssist.Hint="gfx/flags/ENG.tga" materialDesign:HintAssist.IsFloating="False"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding FlagPath}" IsReadOnly="True"
                                     Height="34" VerticalContentAlignment="Center" FontSize="12"/>
                            <Button Grid.Column="2" Style="{StaticResource GhostIconBtn}"
                                    Command="{Binding DataContext.BrowseFlagCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Padding="14,0" Height="34">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderSearch" Width="13" Height="13"
                                                             VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Browse" VerticalAlignment="Center" FontSize="11" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock Text="Country Colour (R G B — values 0–255)" Style="{StaticResource InputLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="R" materialDesign:HintAssist.IsFloating="False"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding ColorR}" Height="34" VerticalContentAlignment="Center" FontSize="12"/>
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="G" materialDesign:HintAssist.IsFloating="False"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding ColorG}" Height="34" VerticalContentAlignment="Center" FontSize="12"/>
                            <TextBox Grid.Column="4" materialDesign:HintAssist.Hint="B" materialDesign:HintAssist.IsFloating="False"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding ColorB}" Height="34" VerticalContentAlignment="Center" FontSize="12"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Starting Setup card -->
                <Border Style="{StaticResource AppCard}" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <materialDesign:PackIcon Kind="Sword" Width="15" Height="15"
                                                     Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="Starting Setup" Style="{StaticResource HeadingSm}"/>
                        </StackPanel>
                        <TextBlock Text="OOB File Path" Style="{StaticResource InputLabel}"/>
                        <TextBox materialDesign:HintAssist.Hint="TAG_1936" materialDesign:HintAssist.IsFloating="False"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding OobPath, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10" Height="34" VerticalContentAlignment="Center" FontSize="12"/>
                        <TextBlock Text="Starting Technologies (space-separated)" Style="{StaticResource InputLabel}"/>
                        <TextBox materialDesign:HintAssist.Hint="infantry_weapons1 artillery1..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding StartingTechnology, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" Height="60" FontSize="12"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
