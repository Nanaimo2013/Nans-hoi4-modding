<UserControl x:Class="NansHoi4Tool.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource MahApps.Brushes.ThemeBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,40" MaxWidth="760">

            <!-- Page header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                <Border Width="40" Height="40" CornerRadius="10" Background="#1A1C27"
                        BorderBrush="#2C2F43" BorderThickness="1" Margin="0,0,14,0">
                    <materialDesign:PackIcon Kind="Cog" Width="20" Height="20"
                                             Foreground="#6366F1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Settings" Style="{StaticResource HeadingLg}"/>
                    <TextBlock Text="Configure your workspace preferences" Style="{StaticResource Caption}"/>
                </StackPanel>
            </StackPanel>

            <!-- PROFILE -->
            <Border Style="{StaticResource AppCard}" Padding="22" Margin="0,0,0,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="AccountOutline" Width="16" Height="16"
                                                 Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Profile" Style="{StaticResource HeadingSm}"/>
                    </StackPanel>
                    <TextBlock Text="Display Name" Style="{StaticResource InputLabel}"/>
                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Your display name"
                             materialDesign:HintAssist.IsFloating="False"
                             Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                             Width="320" HorizontalAlignment="Left" Height="36"/>
                </StackPanel>
            </Border>

            <!-- APPEARANCE -->
            <Border Style="{StaticResource AppCard}" Padding="22" Margin="0,0,0,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="Palette" Width="16" Height="16"
                                                 Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Appearance" Style="{StaticResource HeadingSm}"/>
                    </StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Theme" Style="{StaticResource InputLabel}"/>
                            <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Theme"
                                      ItemsSource="{Binding AvailableThemes}"
                                      SelectedItem="{Binding SelectedTheme}" Height="36"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Accent Color" Style="{StaticResource InputLabel}"/>
                            <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Accent"
                                      ItemsSource="{Binding AvailableAccents}"
                                      SelectedItem="{Binding SelectedAccent}" Height="36"/>
                        </StackPanel>
                    </Grid>
                    <CheckBox Content="Enable UI animations" IsChecked="{Binding AnimationsEnabled}"
                              Style="{StaticResource MaterialDesignCheckBox}" Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- HOI4 PATH -->
            <Border Style="{StaticResource AppCard}" Padding="22" Margin="0,0,0,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="FolderOutline" Width="16" Height="16"
                                                 Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Hearts of Iron 4" Style="{StaticResource HeadingSm}"/>
                    </StackPanel>
                    <TextBlock Text="Game Install Folder" Style="{StaticResource InputLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="C:\Program Files (x86)\Steam\..."
                                 materialDesign:HintAssist.IsFloating="False"
                                 Text="{Binding Hoi4InstallPath, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True" Height="36"/>
                        <Button Grid.Column="2" Style="{StaticResource GhostIconBtn}"
                                Command="{Binding BrowseHoi4PathCommand}"
                                Padding="16,0" Height="36">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FolderSearch" Width="14" Height="14"
                                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Browse" VerticalAlignment="Center" FontSize="12" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- AUTO-SAVE -->
            <Border Style="{StaticResource AppCard}" Padding="22" Margin="0,0,0,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="ContentSaveAll" Width="16" Height="16"
                                                 Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Auto-Save" Style="{StaticResource HeadingSm}"/>
                    </StackPanel>
                    <CheckBox Content="Enable auto-save" IsChecked="{Binding AutoSaveEnabled}"
                              Style="{StaticResource MaterialDesignCheckBox}" Foreground="White"/>
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0"
                                IsEnabled="{Binding AutoSaveEnabled}">
                        <TextBlock Text="Save every" VerticalAlignment="Center" Margin="0,0,10,0"
                                   Foreground="White" Opacity="0.6" FontSize="12"/>
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="60"
                                 materialDesign:HintAssist.IsFloating="False"
                                 Text="{Binding AutoSaveInterval}"
                                 Width="72" Height="32" VerticalContentAlignment="Center"/>
                        <TextBlock Text="seconds" VerticalAlignment="Center" Margin="10,0,0,0"
                                   Foreground="White" Opacity="0.6" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- COLLABORATION -->
            <Border Style="{StaticResource AppCard}" Padding="22" Margin="0,0,0,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="AccountMultiple" Width="16" Height="16"
                                                 Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Collaboration" Style="{StaticResource HeadingSm}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel>
                            <TextBlock Text="Server Port" Style="{StaticResource InputLabel}"/>
                            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="51420"
                                     materialDesign:HintAssist.IsFloating="False"
                                     Text="{Binding ServerPort}"
                                     Width="110" Height="36" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- DISCORD -->
            <Border Style="{StaticResource AppCard}" Padding="22" Margin="0,0,0,24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="Discord" Width="16" Height="16"
                                                 Foreground="#6366F1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Discord Integration" Style="{StaticResource HeadingSm}"/>
                    </StackPanel>
                    <CheckBox Content="Enable Discord Rich Presence" IsChecked="{Binding DiscordEnabled}"
                              Style="{StaticResource MaterialDesignCheckBox}" Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Save button -->
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource GlowButton}" Padding="28,12"
                        Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Save Settings" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
