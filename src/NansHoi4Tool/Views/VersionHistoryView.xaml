<UserControl x:Class="NansHoi4Tool.Views.VersionHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header + actions -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource MahApps.Brushes.Separator}"
                BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Version History" FontSize="24" FontWeight="Light"
                               Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                    <TextBlock Text="Named snapshots of your project state" FontSize="12" Opacity="0.5"
                               Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Command="{Binding CreateSnapshotCommand}"
                        Padding="20,10">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Camera" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Create Snapshot" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Snapshot list + diff panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

        <!-- Diff panel (right) -->
        <Border Grid.Column="2"
                BorderBrush="{DynamicResource MahApps.Brushes.Separator}"
                BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <TextBlock Text="Diff" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,12"/>
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowDiff}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBox Text="{Binding DiffText, Mode=OneWay}"
                                 IsReadOnly="True" AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas" FontSize="11"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                    </StackPanel>
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowDiff}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <materialDesign:PackIcon Kind="Compare" Width="36" Height="36"
                                                 Opacity="0.2" HorizontalAlignment="Center" Margin="0,32,0,8"/>
                        <TextBlock Text="Select a snapshot and click Compare" Opacity="0.3"
                                   HorizontalAlignment="Center" TextAlignment="Center" FontSize="11"
                                   Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Background="Transparent"/>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Snapshots.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <materialDesign:PackIcon Kind="History" Width="64" Height="64"
                                             Opacity="0.2" HorizontalAlignment="Center"/>
                    <TextBlock Text="No snapshots yet" FontSize="16" Opacity="0.35"
                               HorizontalAlignment="Center" Margin="0,12,0,4"
                               Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                    <TextBlock Text="Create a snapshot to save the current project state"
                               FontSize="12" Opacity="0.25" HorizontalAlignment="Center"
                               Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Snapshots}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Margin="0,0,0,12"
                                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                                 Padding="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Accent bar -->
                                    <Border Grid.Column="0" Background="{DynamicResource PrimaryHueMidBrush}"
                                            CornerRadius="4,0,0,4"/>
                                    <!-- Content -->
                                    <StackPanel Grid.Column="1" Margin="16,12">
                                        <TextBlock Text="{Binding Label}" FontSize="15" FontWeight="Medium"
                                                   Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <materialDesign:PackIcon Kind="AccountCircle" Width="14" Height="14"
                                                                     Opacity="0.5" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Author}" FontSize="11" Opacity="0.5"
                                                       Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                                       Margin="4,0,16,0" VerticalAlignment="Center"/>
                                            <materialDesign:PackIcon Kind="Clock" Width="14" Height="14"
                                                                     Opacity="0.5" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding FormattedDate}" FontSize="11" Opacity="0.5"
                                                       Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                                       Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Summary}" FontSize="11" Opacity="0.4"
                                                   Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <!-- Actions -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                materialDesign:ButtonAssist.CornerRadius="6"
                                                Command="{Binding DataContext.CompareWithSelectedCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,6" Margin="0,0,2,0"
                                                ToolTip="Compare with currently selected snapshot">Compare</Button>
                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                materialDesign:ButtonAssist.CornerRadius="6"
                                                Command="{Binding DataContext.RestoreSnapshotCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,6" Margin="0,0,2,0">Restore</Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Width="32" Height="32"
                                                Command="{Binding DataContext.DeleteSnapshotCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                                ToolTip="Delete snapshot">
                                            <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
