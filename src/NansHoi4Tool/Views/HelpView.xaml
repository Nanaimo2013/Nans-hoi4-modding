<UserControl x:Class="NansHoi4Tool.Views.HelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" d:DesignHeight="760" d:DesignWidth="1000"
             Background="{DynamicResource MahApps.Brushes.ThemeBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32,40,40">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <materialDesign:PackIcon Kind="HelpCircleOutline" Width="28" Height="28"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Style="{StaticResource HeadingLg}" Text="Help &amp; Reference" Margin="0"/>
            </StackPanel>
            <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,32"
                       Text="Keyboard shortcuts, editor guides, and tips for using Nan's Hoi4 Tool."/>

            <!-- Two-column layout -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">

                    <!-- ── Keyboard Shortcuts ──────────────────────────── -->
                    <Border Style="{StaticResource AppCard}" Padding="22" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <materialDesign:PackIcon Kind="Keyboard" Width="16" Height="16"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Keyboard Shortcuts" Style="{StaticResource HeadingSm}" Margin="0"/>
                            </StackPanel>

                            <!-- Shortcut rows -->
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="New Project"      Style="{StaticResource Caption}" Margin="0"/>
                                <Border Grid.Column="1" Style="{StaticResource GlassCard}" Padding="6,2" CornerRadius="4"><TextBlock Text="Ctrl + N" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/></Border>
                            </Grid>
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Open Project"     Style="{StaticResource Caption}" Margin="0"/>
                                <Border Grid.Column="1" Style="{StaticResource GlassCard}" Padding="6,2" CornerRadius="4"><TextBlock Text="Ctrl + O" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/></Border>
                            </Grid>
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Save"             Style="{StaticResource Caption}" Margin="0"/>
                                <Border Grid.Column="1" Style="{StaticResource GlassCard}" Padding="6,2" CornerRadius="4"><TextBlock Text="Ctrl + S" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/></Border>
                            </Grid>
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Save As"          Style="{StaticResource Caption}" Margin="0"/>
                                <Border Grid.Column="1" Style="{StaticResource GlassCard}" Padding="6,2" CornerRadius="4"><TextBlock Text="Ctrl + Shift + S" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/></Border>
                            </Grid>
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Export to HOI4"   Style="{StaticResource Caption}" Margin="0"/>
                                <Border Grid.Column="1" Style="{StaticResource GlassCard}" Padding="6,2" CornerRadius="4"><TextBlock Text="Ctrl + Shift + E" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/></Border>
                            </Grid>
                            <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Toggle Sidebar"   Style="{StaticResource Caption}" Margin="0"/>
                                <Border Grid.Column="1" Style="{StaticResource GlassCard}" Padding="6,2" CornerRadius="4"><TextBlock Text="Ctrl + B" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/></Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Focus Tree Editor ──────────────────────────── -->
                    <Border Style="{StaticResource AppCard}" Padding="22" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <materialDesign:PackIcon Kind="FileTreeOutline" Width="16" Height="16"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Focus Tree Editor" Style="{StaticResource HeadingSm}" Margin="0"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,10"
                                       Text="The focus tree editor lets you visually design national focus trees for HOI4 mods."/>
                            <Border Style="{StaticResource GlassCard}" Padding="12,10" Margin="0,0,0,8" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,4" FontWeight="SemiBold" Opacity="0.8" Text="Node Controls"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,2" Text="• Drag nodes freely on the canvas"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,2" Text="• Click a node to select and inspect it"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,2" Text="• Scroll wheel to zoom in / out"/>
                                    <TextBlock Style="{StaticResource Caption}" Text="• Middle-click drag to pan the canvas"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource GlassCard}" Padding="12,10" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,4" FontWeight="SemiBold" Opacity="0.8" Text="Connect Mode"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,2" Text="• Click the link icon to enter Connect Mode"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,2" Text="• Click a source node, then a target node"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,2" Text="• Choose Prerequisite or Mutually Exclusive"/>
                                    <TextBlock Style="{StaticResource Caption}" Text="• Press Escape to cancel"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── Collaboration ──────────────────────────────── -->
                    <Border Style="{StaticResource AppCard}" Padding="22">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <materialDesign:PackIcon Kind="AccountMultiple" Width="16" Height="16"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="LAN Collaboration" Style="{StaticResource HeadingSm}" Margin="0"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,10"
                                       Text="Work on a mod together in real-time over your local network or Hamachi."/>
                            <Border Style="{StaticResource GlassCard}" Padding="12,10" Margin="0,0,0,8" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Caption}" FontWeight="SemiBold" Opacity="0.8" Margin="0,0,0,4" Text="Host (project owner)"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,2" Text="1. Open your project"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,2" Text="2. Go to Collaboration → Start Hosting"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,2" Text="3. Share your displayed local IP with guests"/>
                                    <TextBlock Style="{StaticResource Caption}" Text="4. Use Sync button to push updates mid-session"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource GlassCard}" Padding="12,10" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Caption}" FontWeight="SemiBold" Opacity="0.8" Margin="0,0,0,4" Text="Guest (no file needed)"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,2" Text="1. Go to Collaboration → Connect"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,2" Text="2. Enter the host's IP and port (default 51420)"/>
                                    <TextBlock Style="{StaticResource Caption}" Text="3. The project loads automatically from the host"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <StackPanel Grid.Column="2">

                    <!-- ── Getting Started ────────────────────────────── -->
                    <Border Style="{StaticResource AppCard}" Padding="22" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <materialDesign:PackIcon Kind="Rocket" Width="16" Height="16"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Getting Started" Style="{StaticResource HeadingSm}" Margin="0"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,10"
                                       Text="New to modding HOI4? Here's the recommended workflow:"/>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="{DynamicResource PrimaryHueMidBrush}" Width="22" Height="22"
                                            CornerRadius="11" Margin="0,0,10,0">
                                        <TextBlock Text="1" FontSize="11" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0"
                                               Text="Create a new project (File → New Project)"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="{DynamicResource PrimaryHueMidBrush}" Width="22" Height="22"
                                            CornerRadius="11" Margin="0,0,10,0">
                                        <TextBlock Text="2" FontSize="11" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0"
                                               Text="Set your HOI4 install path in Settings"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="{DynamicResource PrimaryHueMidBrush}" Width="22" Height="22"
                                            CornerRadius="11" Margin="0,0,10,0">
                                        <TextBlock Text="3" FontSize="11" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0"
                                               Text="Design your country, focus trees, events"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource PrimaryHueMidBrush}" Width="22" Height="22"
                                            CornerRadius="11" Margin="0,0,10,0">
                                        <TextBlock Text="4" FontSize="11" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0"
                                               Text="Export mod (Ctrl+Shift+E) and test in HOI4"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Editors Overview ───────────────────────────── -->
                    <Border Style="{StaticResource AppCard}" Padding="22" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <materialDesign:PackIcon Kind="ViewGrid" Width="16" Height="16"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Editors" Style="{StaticResource HeadingSm}" Margin="0"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="FileTreeOutline" Width="14" Height="14"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                         VerticalAlignment="Top" Margin="0,1,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Focus Trees" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0"
                                               Text="Visual canvas editor for national focus trees. Supports multi-tree tabs."/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="CalendarText" Width="14" Height="14"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                         VerticalAlignment="Top" Margin="0,1,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Events" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0"
                                               Text="Create and manage country events with options and effects."/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="Flag" Width="14" Height="14"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                         VerticalAlignment="Top" Margin="0,1,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Country" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0"
                                               Text="Define country tag, ideology, graphics, and starting setup."/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="Translate" Width="14" Height="14"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                         VerticalAlignment="Top" Margin="0,1,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Localisation" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0"
                                               Text="Manage all translatable strings for your mod in one place."/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="Microscope" Width="14" Height="14"
                                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                         VerticalAlignment="Top" Margin="0,1,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Technologies" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0"
                                               Text="Add custom technologies and tech tree branches."/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Tips ───────────────────────────────────────── -->
                    <Border Style="{StaticResource AppCard}" Padding="22">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <materialDesign:PackIcon Kind="LightbulbOutline" Width="16" Height="16"
                                                         Foreground="#F59E0B"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Tips &amp; Tricks" Style="{StaticResource HeadingSm}" Margin="0"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,6"
                                       Text="💡 Use auto-save (Settings) to avoid losing work during long sessions."/>
                            <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,6"
                                       Text="💡 Import an existing mod via File → Import to use it as a starting point."/>
                            <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,6"
                                       Text="💡 Focus tree nodes snap to a grid — hold Alt to fine-position."/>
                            <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,6"
                                       Text="💡 Version History shows a full changelog of your project edits."/>
                            <TextBlock Style="{StaticResource Caption}"
                                       Text="💡 The Discord integration shows your mod name in Rich Presence."/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
